let math = import("math.nin");
print(math.square(4));
print(math.PI);

class Circle {
    fun init(r) {
        this.radius = r;
    }
    fun area() {
        let pi = import("math.nin").PI;
        return pi * this.radius * this.radius;
    }
}

let c = new Circle(5);
print(c.area());

let i = 0;
while (i < 5) {
    print(i);
    i = i + 1;
}

if (c.area() > 50) {
    print("big cirlcle!");
} else {
    print("small circle!");
}
